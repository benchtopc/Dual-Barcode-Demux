manifest {
    name            = 'benchtopc/Dual-Barcode-Demux'
    author          = 'SCM'
    homePage        = 'https://github.com/benchtopc/Dual-Barcode-Demux'
    description     = 'EPI2ME-compatible Nextflow workflow for dual-barcode demultiplexing, per-sample alignment, Clair3 GPU variant calling, KO calls, and IGV reports.'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '0.4.0'
}

params {
    fastq = null
    plate_map = null
    row_barcodes = "${projectDir}/data/scm_row_barcodes.csv"
    column_barcodes = "${projectDir}/data/scm_column_barcodes.csv"
    front_window = 200
    rear_window = 200
    max_linker_mismatches = 2
    max_total_score = 4
    min_margin = 2
    keep_partial = true

    run_alignment = false
    reference = null
    ko_targets = "${projectDir}/templates/ko_targets.template.tsv"
    aligner_preset = "map-ont"
    alignment_threads = 4
    min_mapq = 10
    min_baseq = 7
    min_depth_ko = 10
    het_min_af = 0.25
    hom_alt_min_af = 0.80
    keep_unfiltered_bam = false

    variant_caller = "bcftools"
    enable_gpu = false
    gpu_devices = "all"
    igv_locus = "all"

    clair3_model_path = "/opt/models/r1041_e82_400bps_sup_v500"
    clair3_model_dir = ""
    clair3_platform = "ont"
    clair3_bed = "${projectDir}/templates/empty.bed"
    clair3_ctg_name = ""
    clair3_enable_dwell_time = false
    clair3_include_all_ctgs = true
    clair3_haploid_mode = "none"
    clair3_no_phasing_for_fa = false
    clair3_pileup_only = false
    clair3_print_ref_calls = false
    clair3_gvcf = false
    clair3_qual = 2
    clair3_chunk_size = 0
    clair3_remove_intermediate_dir = true
    clair3_device = "cuda:0"
    clair3_extra_args = ""
    clair3_cpu_container = "hkubal/clair3:v2.0.1"
    clair3_gpu_container = "hkubal/clair3:v2.0.1_gpu"

    out_dir = 'output'
    help = false
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 0

    withName: DEMUX_SCM {
        cpus = 1
        memory = '4 GB'
        time = '8h'
    }

    withName: ALIGN_SCM {
        cpus = { params.alignment_threads as int }
        memory = '8 GB'
        time = '24h'
    }

    withName: BCFTOOLS_CALL_SCM {
        cpus = { params.alignment_threads as int }
        memory = '8 GB'
        time = '24h'
    }

    withName: CLAIR3_CALL_SCM {
        cpus = { params.alignment_threads as int }
        memory = '16 GB'
        time = '48h'
        containerOptions = { (params.variant_caller == 'clair3_gpu' || params.enable_gpu) ? "--gpus ${params.gpu_devices}" : "" }
    }

    withName: ANALYZE_KO_IGV_SCM {
        cpus = 1
        memory = '4 GB'
        time = '8h'
    }
}

profiles {
    standard {
    }

    docker {
        docker.enabled = true
    }

    gpu {
        docker.enabled = true
        params.enable_gpu = true
        params.variant_caller = 'clair3_gpu'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }

    demo {
        params.fastq = "${projectDir}/tests/data/demo.fastq.gz"
        params.plate_map = "${projectDir}/templates/plate_map.template.csv"
        params.run_alignment = true
        params.reference = "${projectDir}/tests/data/demo_reference.fa"
        params.ko_targets = "${projectDir}/templates/ko_targets.template.tsv"
        params.min_depth_ko = 1
        params.out_dir = "demo_output"
    }
}
